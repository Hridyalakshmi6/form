# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Your Google Spreadsheet ID (from the URL)
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Paste the entire JSON content of your service account key file here
# Make sure it's on one line (minified JSON)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
